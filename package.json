{
  "name": "@overdraft-protocol/inspect-tools",
  "version": "0.1.1",
  "description": "Render real ext-apps HTML panels against a mock MCP host for fast iteration",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/overdraft-protocol/inspect-tools.git"
  },
  "homepage": "https://github.com/overdraft-protocol/inspect-tools#readme",
  "bugs": {
    "url": "https://github.com/overdraft-protocol/inspect-tools/issues"
  },
  "bin": {
    "inspect-tools": "dist/cli.js",
    "inspect-tools-mcp": "dist/mcp-server.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prepublishOnly": "npm run build",
    "dev": "tsc -p tsconfig.json --watch",
    "example:build": "node example/build.mjs",
    "selftest": "npm run build && npm run example:build && node example/selftest.mjs && node example/selftest-cli.mjs",
    "postinstall": "echo 'Run: npx playwright install chromium'"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "files": [
    "dist"
  ],
  "dependencies": {
    "@modelcontextprotocol/ext-apps": "^1.7.5",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "jsdom": "^25.0.1",
    "playwright": "^1.48.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/jsdom": "^21.1.7",
    "@types/node": "^22.9.0",
    "esbuild": "^0.28.1",
    "typescript": "^5.6.3"
  }
}
