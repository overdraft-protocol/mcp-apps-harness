{
  "name": "mcp-apps-harness",
  "version": "0.1.0",
  "description": "Render real ext-apps HTML panels against a mock MCP host for fast iteration",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "mcp-apps-harness": "dist/cli.js",
    "mcp-apps-harness-mcp": "dist/mcp-server.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "example:build": "node example/build.mjs",
    "selftest": "npm run build && npm run example:build && node example/selftest.mjs && node example/selftest-cli.mjs",
    "postinstall": "echo 'Run: npx playwright install chromium'"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "files": [
    "dist"
  ],
  "dependencies": {
    "@modelcontextprotocol/ext-apps": "^1.7.5",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "jsdom": "^25.0.1",
    "playwright": "^1.48.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/jsdom": "^21.1.7",
    "@types/node": "^22.9.0",
    "esbuild": "^0.28.1",
    "typescript": "^5.6.3"
  }
}
